# ============================================================
#  Campus Trade 环境变量配置
#  使用方法：复制此文件为 .env，按需修改各值
#  Windows: copy .env.example .env
#  Linux/Mac: cp .env.example .env
# ============================================================


# ── 服务器 ──────────────────────────────────────────────────
SERVER_PORT=8080


# ── 数据库 (MySQL) ─────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/campus_trade?useSSL=false&serverTimezone=Asia/Shanghai&useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci&allowPublicKeyRetrieval=true
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_USERNAME=root
DB_PASSWORD=135790


# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=110.40.131.82
REDIS_PORT=6379
REDIS_PASSWORD=135790zs
REDIS_DATABASE=0
REDIS_REQUIRED=true


# ── JWT 认证 ───────────────────────────────────────────────
# 请生成一个随机的 Base64 密钥，不要使用示例值
# 生成命令: openssl rand -base64 64
JWT_SECRET=bXlfc3VwZXJfc2VjdXJlX2p3dF9rZXlfZm9yX2NhbXB1c190cmFkZV9hcHA=
JWT_EXPIRATION_MINUTES=1440

# 登录安全
AUTH_MAX_LOGIN_FAILURES=5
AUTH_LOCK_MINUTES=15


# ── 邮件 (SMTP) ───────────────────────────────────────────
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=2475594430@qq.com
MAIL_PASSWORD=xanenspgxrmkecba
MAIL_FROM=2475594430@qq.com
APP_MAIL_ENABLED=true


# ── 验证码 ─────────────────────────────────────────────────
VERIFICATION_CODE_EXPIRE_MINUTES=5
VERIFICATION_CODE_RESEND_COOLDOWN=60
VERIFICATION_CODE_HOURLY_LIMIT=8
VERIFICATION_CODE_DEBUG_RETURN=false


# ── 缓存 ──────────────────────────────────────────────────
CACHE_CATEGORY_TTL_MINUTES=30
CACHE_GOODS_LIST_TTL_MINUTES=2


# ── MinIO 对象存储 ─────────────────────────────────────────
MINIO_ENDPOINT=http://110.40.131.82:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=135790zs
MINIO_BUCKET=campus-trade
MINIO_PUBLIC_BASE_URL=http://110.40.131.82:9000/campus-trade
MINIO_SECURE=false
MINIO_AUTO_CREATE_BUCKET=true
